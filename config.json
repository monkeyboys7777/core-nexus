  "macros": {
    "study_mode": {
      "description": "Close games and Discord, open school portal",
      "actions": [
        {
          "type": "kill",
          "process": "TmForever.exe",
          "name": "Trackmania"
        },
        {
          "type": "kill",
          "process": "Minecraft.exe",
          "name": "Minecraft"
        },
        {
          "type": "kill",
          "process": "Discord.exe",
          "name": "Discord"
        },
        {
          "type": "volume",
          "level": 30
        },
        {
          "delay": 1
        },
        {
          "type": "url",
          "url": "https://YOUR_SCHOOL_PORTAL_URL_HERE"
        },
        {
          "type": "speak",
          "text": "Study mode active. Distractions eliminated."
        }
      ]
    },
    "game_mode": {
      "description": "Launch Discord, set volume to 60, close background apps",
      "actions": [
        {
          "type": "kill",
          "process": "chrome.exe",
          "name": "Chrome"
        },
        {
          "type": "volume",
          "level": 60
        },
        {
          "delay": 1
        },
        {
          "type": "launch",
          "key": "discord"
        },
        {
          "type": "speak",
          "text": "Game mode activated. Discord launched."
        }
      ]
    },
    "night_mode": {
      "description": "Low volume, close everything, prepare to wind down",
      "actions": [
        {
          "type": "volume",
          "level": 15
        },
        {
          "type": "speak",
          "text": "Night mode engaged. Volume reduced."
        }
      ]
    }
  },
